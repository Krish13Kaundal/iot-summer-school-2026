/*
 * Author: Krish
 * Date: July 2026
 * Description: LED blink program with serial monitoring and potentiometer control.
 */
int blinkCount = 0;
int potPin = A0;

void setup() {
  pinMode(13, OUTPUT);
  Serial.begin(9600);
}
void loop() {
  int potValue = analogRead(potPin);

  digitalWrite(13, HIGH);
  delay(potValue);
  digitalWrite(13, LOW);
  delay(potValue);

  blinkCount++;
  Serial.print("Blink count: ");
  Serial.println(blinkCount);
}
